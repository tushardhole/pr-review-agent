{
  "name": "pr-review-agent",
  "version": "0.1.0",
  "description": "GitHub Action for AI-powered pull request reviews.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "ncc build build/src/index.js -o dist",
    "package": "npm run build && npm run bundle",
    "test": "jest --runInBand",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "github-actions",
    "code-review",
    "openai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "minimatch": "^9.0.5",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.17",
    "@vercel/ncc": "^0.38.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
